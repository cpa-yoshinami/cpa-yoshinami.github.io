{
  "name": "yoshinami-cpa-office",
  "version": "1.0.0",
  "description": "ホームページ「善波公認会計士税理士事務所」の公式サイト",
  "main": "src/index.html",
  "scripts": {
    "start": "five-server src",
    "build": "npx @tailwindcss/cli -i ./src/assets/input.css -o ./src/assets/styles.css --watch",
    "build-prod": "npx @tailwindcss/cli -i ./src/assets/input.css -o ./src/assets/styles.css --minify",
    "format": "prettier --write \"src/**/*.{html,css,js}\""
  },
  "author": "善波公認会計士税理士事務所",
  "license": "MIT",
  "devDependencies": {
    "@tailwindcss/cli": "^4.2.2",
    "five-server": "^0",
    "prettier": "^3",
    "prettier-plugin-tailwindcss": "^0.7.2",
    "tailwindcss": "^4.2.2"
  }
}
